{
  "name": "murflame-launcher",
  "version": "15.06.26",
  "description": "MurFlame — Minecraft Launcher с лицензией и офлайн-режимом",
  "main": "dist-electron/main.js",
  "type": "module",
  "author": "MurSoftware, inc",
  "license": "MIT",
  "homepage": ".",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:electron && npm run build:vite",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:vite": "vite build",
    "build:installer": "node build-installer.cjs",
    "dist": "npm run build && npm run dist:portable && npm run dist:nsis",
    "dist:full": "npm run dist && npm run build:installer",
    "dist:portable": "electron-builder --win portable --x64",
    "dist:nsis": "electron-builder --win nsis --x64",
    "preview": "vite preview",
    "start": "electron dist-electron/main.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.murflame.launcher",
    "productName": "MurFlame Launcher",
    "copyright": "Copyright © 2026 MurFlame Team",
    "directories": {
      "output": "release",
      "buildResources": "assets",
      "app": "."
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}_${version}.${ext}",
      "publisherName": "MurFlame"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "!dist-electron/*.ts",
      "!dist-electron/*.map",
      "!dist-electron/*.tsbuildinfo",
      "!node_modules/.cache",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ]
  },
  "dependencies": {
    "@types/pngjs": "^6.0.5",
    "@xmcl/core": "^2.15.1",
    "@xmcl/installer": "^6.1.2",
    "@xmcl/user": "^4.2.0",
    "adm-zip": "^0.5.17",
    "electron-store": "^8.2.0",
    "fs-extra": "^11.3.5",
    "iconv-lite": "^0.7.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "pngjs": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0",
    "tar": "^7.5.15",
    "three": "^0.184.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/fs-extra": "^11.0.4",
    "@types/iconv-lite": "^0.0.1",
    "@types/jszip": "^3.4.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/tar": "^6.1.13",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.1",
    "wait-on": "^8.0.1"
  }
}
